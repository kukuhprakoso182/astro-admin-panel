<dialog
    id="global-modal"
    class="fixed inset-0 m-auto backdrop:bg-black/40 backdrop:backdrop-blur-sm rounded-3xl p-0 border-none shadow-2xl overflow-visible open:flex items-center justify-center"
>
    <div
        class="w-[90vw] max-w-md bg-white p-8 rounded-3xl flex flex-col gap-6 relative"
    >
        <div class="flex flex-col gap-3">
            <h3
                id="modal-title"
                class="text-2xl font-bold text-gray-950 tracking-tight"
            >
                Privacy info
            </h3>
            <p
                id="modal-description"
                class="text-[15px] leading-relaxed text-gray-600"
            >
                The backups created with this functionality may contain some
                sensitive data.
            </p>
        </div>

        <div class="grid grid-cols-2 gap-4 pt-2">
            <button
                onclick="this.closest('dialog').close()"
                class="w-full py-3.5 px-5 text-center bg-gray-100 text-gray-900 font-semibold rounded-xl hover:bg-gray-200 transition-colors text-base"
            >
                Cancel
            </button>
            <button
                id="modal-confirm-btn"
                class="w-full py-3.5 px-5 text-center bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 transition-colors text-base shadow-sm"
            >
                Confirm
            </button>
        </div>
    </div>
</dialog>

<script>
    import { openModal } from "./dialog"; // Impor fungsi helpers

    const modal = document.getElementById("global-modal") as HTMLDialogElement;
    const titleElem = document.getElementById("modal-title");
    const descElem = document.getElementById("modal-description");

    // Mendengarkan event 'open-modal'
    window.addEventListener("open-modal", (e: any) => {
        const { title, description } = e.detail;

        // Update konten jika ada data yang dikirim
        if (title && titleElem) titleElem.innerText = title;
        if (description && descElem) descElem.innerText = description;

        modal.showModal();
    });

    // Menutup modal jika area luar (backdrop) diklik
    modal.addEventListener("click", (e) => {
        if (e.target === modal) modal.close();
    });
</script>

<style>
    /* Animasi Fade In */
    dialog[open] {
        animation: fadeIn 0.3s ease-out forwards;
    }

    /* Styling khusus untuk backdrop (area buram di luar modal) */
    dialog::backdrop {
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(4px);
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: scale(0.95);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>
