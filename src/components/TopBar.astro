---
---

<header class="top-bar">
  <div class="breadcrumb">
    <span class="breadcrumb-parent">Maham</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
    <span class="breadcrumb-icon">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
      </svg>
    </span>
    <span class="breadcrumb-current">Attendance</span>
  </div>

  <div class="header-actions">
    <button class="icon-btn notification">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
      </svg>
    </button>
    <button class="icon-btn message">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      <span class="action-badge">2</span>
    </button>
    <button class="icon-btn search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </button>
  </div>
</header>

<style>
  .top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 24px;
    border-bottom: 1px solid #eef2ee;
    background: white;
    font-family: 'DM Sans', sans-serif;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
  }

  .breadcrumb-parent {
    color: #8a9a8a;
    font-weight: 500;
  }

  .breadcrumb svg { color: #c0ccc0; }

  .breadcrumb-icon {
    display: flex;
    align-items: center;
    color: #5a6a5a;
  }

  .breadcrumb-current {
    color: #2d3a2d;
    font-weight: 600;
  }

  .header-actions {
    display: flex;
    gap: 4px;
  }

  .icon-btn {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    border: 1px solid #eef2ee;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #5a6a5a;
    position: relative;
    transition: all 0.12s;
  }

  .icon-btn:hover {
    background: #f8faf8;
    color: #2d3a2d;
  }

  .action-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    background: #e05050;
    color: white;
    font-size: 9px;
    font-weight: 700;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid white;
  }
</style>
