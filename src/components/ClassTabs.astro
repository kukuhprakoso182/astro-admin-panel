---
const classes = [
  { name: "Class 302", active: true },
  { name: "Class 303", active: false },
  { name: "Class 304", active: false },
];
---

<div class="class-tabs">
  {classes.map((cls) => (
    <button class={`class-tab ${cls.active ? "active" : ""}`}>
      {cls.active && (
        <span class="tab-dot">
          <svg width="8" height="8" viewBox="0 0 10 10">
            <circle cx="5" cy="5" r="5" fill="currentColor"/>
          </svg>
        </span>
      )}
      {cls.name}
    </button>
  ))}
</div>

<style>
  .class-tabs {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .class-tab {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    border: 1px solid #dde8dd;
    background: white;
    color: #5a6a5a;
    transition: all 0.15s ease;
    font-family: 'DM Sans', sans-serif;
  }

  .class-tab:hover:not(.active) {
    background: #f0f4f0;
  }

  .class-tab.active {
    background: #2d3a2d;
    color: white;
    border-color: #2d3a2d;
  }

  .tab-dot {
    display: flex;
    align-items: center;
    color: rgba(255,255,255,0.7);
  }
</style>
