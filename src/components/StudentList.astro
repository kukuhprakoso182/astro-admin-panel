---
interface Student {
  initials: string;
  name: string;
  color: string;
}

interface Props {
  title: string;
  count: number;
  type: "attendance" | "absences" | "delayed";
  students: Student[];
}

const { title, count, type, students } = Astro.props;
---

<div class="student-list-column">
  <div class="column-header">
    <span class={`column-icon ${type}`}>
      {type === "attendance" && (
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      )}
      {type === "absences" && (
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      )}
      {type === "delayed" && (
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      )}
    </span>
    <span class="column-title">{title}</span>
    <span class="column-count">{count}</span>
  </div>

  <ul class="student-list">
    {students.map((student) => (
      <li class="student-item">
        <div class="student-avatar" style={`background: ${student.color}15; color: ${student.color}`}>
          {student.initials}
        </div>
        <span class="student-name">{student.name}</span>
        <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </li>
    ))}
  </ul>
</div>

<style>
  .student-list-column {
    flex: 1;
    min-width: 0;
  }

  .column-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0 0 10px;
    border-bottom: 1px solid #f0f0f0;
    margin-bottom: 4px;
  }

  .column-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 4px;
  }

  .column-icon.attendance { color: #3d9a3d; }
  .column-icon.absences, .column-icon.delayed { color: #8a9a8a; }

  .column-title {
    font-size: 13px;
    font-weight: 600;
    color: #3a4a3a;
    flex: 1;
  }

  .column-count {
    font-size: 12px;
    font-weight: 700;
    color: white;
    background: #2d3a2d;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .student-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .student-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 6px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.12s;
  }

  .student-item:hover {
    background: #f8faf8;
  }

  .student-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .student-name {
    font-size: 12.5px;
    color: #3a4a3a;
    font-weight: 500;
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .chevron {
    color: #c0ccc0;
    flex-shrink: 0;
  }
</style>
