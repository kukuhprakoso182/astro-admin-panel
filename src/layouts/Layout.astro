---
import "../styles/global.css";
import Alert from "../components/ui/alert/Alert.astro";
import Modal from "../components/ui/Modal.astro";

interface AlertData {
    variant: "success" | "error" | "warning" | "info";
    title: string;
    message: string;
}

interface Props {
    title: string;
    alert?: AlertData | null;
}

const { title, alert: alertProp } = Astro.props;

// Ambil alert dari session (untuk flash message setelah redirect)
const sessionAlert = (await Astro.session?.get("alert")) as AlertData | null;
// Hapus setelah dapat nilainya
if (sessionAlert) {
    await Astro.session?.delete("alert");
}

// Props alert lebih prioritas dari session alert
const alert = alertProp ?? sessionAlert ?? null;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title + " - Admin Panel" || "Admin Panel"}</title>
    </head>
    <body class="font-default bg-white">
        {
            alert && (
                <Alert
                    variant={alert.variant}
                    title={alert.title}
                    message={alert.message}
                    position="top-right"
                />
            )
        }
        <Modal />
        <slot />
    </body>
</html>
