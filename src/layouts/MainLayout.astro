---
import "../styles/global.css";
import { Image } from "astro:assets";
import logoImage from "../assets/logo.svg";

interface Props {
	title?: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title + " - Admin Panel" || "Admin Panel"}</title>
	</head>
	<body class="flex min-h-screen max-w-300 overflow-hidden">
		<aside
			class="flex bg-red-300 w-52.5 flex-col py-4 shrink-0 transition-[width] duration-280 ease-in-out overflow-hidden group/sidebar [&.collapsed]:w-14.5"
		>
			<div
				class="flex items-center justify-between px-3.5 pb-4 shrink-0 group-[.collapsed]/sidebar:justify-center group-[.collapsed]/sidebar:px-0"
			>
				<div
					class="grid grid-cols-2 gap-0.75 w-5.5 h-5.5 shrink-0 cursor-default"
				>
					<!-- <Image src="../assets/logo.svg" alt="logo" /> -->
					<Image
						src={logoImage}
						alt="logo"
						width={100}
						height={100}
					/>
				</div>
				<button
					class="bg-transparent border-none cursor-pointer text-[#8a9a8a] p-1 rounded-[5px] flex items-center shrink-0 transition-colors duration-[130ms] hover:bg-[#e4e9e4] hover:text-[#2d3a2d] group-[.collapsed]/sidebar:hidden"
				>
					<svg
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
					>
						<rect x="3" y="3" width="18" height="18" rx="2"></rect>
						<line x1="9" y1="3" x2="9" y2="21"></line>
					</svg>
				</button>
			</div>
		</aside>
	</body>
</html>
