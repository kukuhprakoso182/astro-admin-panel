---
import Form from "../../components/ui/Form.astro";
import Logo from "../../components/ui/Logo.astro";
import Input from "../../components/ui/Input.astro";
import Button from "../../components/ui/Button.astro";
import Layout from "../../layouts/GuestLayout.astro";
import { actions } from "astro:actions";
import Alert from "../../components/ui/Alert.astro";
---

<Layout title="Login">
    <Alert
        variant="success"
        message="Data berhasil disimpan."
        position="top-right"
    />
    <Alert
        variant="error"
        message="Gagal menghapus item."
        position="top-right"
    />
    <Alert
        variant="warning"
        message="Sesi hampir habis."
        position="top-right"
    />

    <div class="flex items-center justify-center h-screen">
        <div
            class="w-full max-w-md p-4 space-y-6 bg-white rounded-4xl lg:shadow-2xl m-2 lg:m-0 transition-all duration-300"
        >
            <div class="flex justify-center">
                <Logo size="xl" />
            </div>
            <span class="block text-xl font-bold text-center">
                Welcome Back
            </span>
            <Form action={actions.auths.login} method="POST">
                <div class="gap-2">
                    <Input
                        id="email"
                        name="email"
                        label="Email"
                        type="email"
                        autocomplete="email"
                        variant="filled"
                        required
                    />
                </div>
                <div class="gap-2">
                    <Input
                        id="password"
                        name="password"
                        label="Password"
                        type="password"
                        autocomplete="off"
                        variant="filled"
                        required
                    />
                </div>
                <div>
                    <Button
                        type="submit"
                        variant="primary"
                        size="lg"
                        isFullWidth
                    >
                        Login
                    </Button>
                </div>
            </Form>
            <form action="/auths/login" method="POST" class="space-y-5"></form>
        </div>
    </div>
</Layout>
